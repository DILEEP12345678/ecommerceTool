# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.

# ── Convex ───────────────────────────────────────────────────────────────────
# Generated automatically by `npx convex dev`. Do not edit manually.
# Find your deployment URL at: https://dashboard.convex.dev
CONVEX_DEPLOYMENT=dev:your-deployment-name

# Public Convex API URL (safe to expose — it's the API endpoint, not a secret)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud

# ── Sentry ───────────────────────────────────────────────────────────────────
# Public DSN (safe to expose — designed to be client-visible)
# Find at: sentry.io → Your Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://abc123@o000000.ingest.sentry.io/000000

# Sentry org slug (visible in your Sentry URL: sentry.io/organizations/<slug>)
SENTRY_ORG=your-org-slug

# Sentry project slug (visible at: sentry.io → Projects)
SENTRY_PROJECT=your-project-slug

# Sentry auth token — used only at BUILD TIME to upload source maps.
# Generate at: sentry.io → Settings → Auth Tokens → Create New Token
# Required scopes: project:releases, org:read
# Also add this to your CI/CD environment (Vercel, GitHub Actions, etc.)
# and remove it from any local .env files used in shared environments.
SENTRY_AUTH_TOKEN=sntrys_...

# ── Clerk Auth ───────────────────────────────────────────────────────────────
# Publishable key is safe to expose (NEXT_PUBLIC_ prefix)
# Secret key must NEVER be exposed to the browser
# Find both at: clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk JWT issuer domain — needed by Convex to verify Clerk JWTs.
# Find at: clerk.com → Your App → Domains (the "Frontend API" URL)
# Add to Convex via: npx convex env set CLERK_JWT_ISSUER_DOMAIN https://...clerk.accounts.dev
# (This is a Convex server env var, NOT stored in this file)
